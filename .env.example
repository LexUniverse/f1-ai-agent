# Скопируйте в файл `.env` в корне репозитория и заполните значения.
# `cp .env.example .env` — затем отредактируйте `.env`.

# Обязательно для реальных вызовов GigaChat:
# «Ключ авторизации» из личного кабинета (Base64 authorization data для Basic),
# см. README SDK: https://github.com/ai-forever/gigachat
GIGACHAT_CREDENTIALS=

# По умолчанию в SDK уже GIGACHAT_API_PERS — раскомментируйте при другом scope:
# GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Опционально:
# GIGACHAT_MODEL=GigaChat
# GIGACHAT_TIMEOUT=30
# GIGACHAT_MAX_RETRIES=2
# GIGACHAT_VERIFY_SSL_CERTS=true
# GIGACHAT_CA_BUNDLE_FILE=/ абсолютный/путь/к/сертификатам.pem

# Другие переменные приложения (если используете):
# AUTH_ALLOWLIST_CODES=ABC123,XYZ789
# Streamlit → API (локально):
# F1_API_BASE_URL=http://127.0.0.1:8000
