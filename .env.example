# Скопируйте в файл `.env` в корне репозитория и заполните значения.
# `cp .env.example .env` — затем отредактируйте `.env`.

# Обязательно для реальных вызовов GigaChat:
# «Ключ авторизации» из личного кабинета (Base64 authorization data для Basic),
# см. README SDK: https://github.com/ai-forever/gigachat
GIGACHAT_CREDENTIALS=

# По умолчанию в SDK уже GIGACHAT_API_PERS — раскомментируйте при другом scope:
# GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Опционально:
# GIGACHAT_MODEL=GigaChat
# GIGACHAT_TIMEOUT=30
# GIGACHAT_MAX_RETRIES=2
# GIGACHAT_VERIFY_SSL_CERTS=true
#
# TLS НУЦ Минцифры (см. https://developers.sber.ru/docs/ru/gigachat/certificates):
# Если GIGACHAT_CA_BUNDLE_FILE не задан, приложение само возьмёт certs/russiantrustedca2024.pem
# или certs/russiantrustedca.pem из корня репозитория, если файлы есть.
# Путь может быть абсолютным или относительным к корню репозитория:
# GIGACHAT_CA_BUNDLE_FILE=certs/russiantrustedca2024.pem
#
# Для curl без -k укажите тот же файл: --cacert certs/russiantrustedca2024.pem
# (иначе curl использует свой набор CA и ругается на цепочку НУЦ).

# Обязательно, если при слабом RAG нужен веб-поиск (LangGraph → Tavily):
# https://tavily.com — API key в личном кабинете
TAVILY_API_KEY=

# Опционально для Tavily:
# TAVILY_TIMEOUT=10
# TAVILY_MAX_RESULTS=5

# Другие переменные приложения (если используете):
# AUTH_ALLOWLIST_CODES=ABC123,XYZ789
# Streamlit → API (локально):
# F1_API_BASE_URL=http://127.0.0.1:8000

# RAG / Chroma — одна модель для индекса и запросов (sentence-transformers).
# Если каталог embedding_model/ в корне репозитория заполнен (скачать один раз):
#   python3 -c "from huggingface_hub import snapshot_download; snapshot_download('ai-forever/ru-en-RoSBERTa', local_dir='embedding_model')"
# переменную можно не задавать — код сам возьмёт локальный путь.
# Явно с Hub (без локальной копии):
# F1_EMBEDDING_MODEL=ai-forever/ru-en-RoSBERTa
